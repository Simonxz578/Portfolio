---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactPanel from "@components/ContactPanel.astro";
import ProjectCard from "@components/ProjectCard.astro";
import SectionIntro from "@components/SectionIntro.astro";
import { capabilities, selectedExperience } from "@data/en/experience";
import { featuredProjects } from "@data/en/projects";
import { researchItems } from "@data/en/research";
import { site } from "@data/site";
import { withBase } from "../utils/urls";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  alternateName: "Simon Zhang",
  url: new URL(withBase("/"), Astro.site ?? Astro.url.origin).href,
  jobTitle: site.role,
  knowsAbout: [
    "Applied artificial intelligence",
    "AI product management",
    "Large language model workflows",
    "Retrieval-augmented generation",
    "Model evaluation",
    "Organisational AI adoption"
  ],
  affiliation: {
    "@type": "CollegeOrUniversity",
    name: "University of Cambridge"
  },
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "University College London" },
    { "@type": "CollegeOrUniversity", name: "University of Manchester" }
  ],
  sameAs: [site.linkedin]
};
---

<BaseLayout
  title={site.displayName}
  description="Xiang Zhang (Simon) works across applied AI, product judgement, model evaluation, workflow engineering and organisational adoption."
  structuredData={personSchema}
>
  <section class="home-hero">
    <div class="shell home-hero-grid">
      <div class="home-hero-copy">
        <p class="eyebrow">Xiang Zhang (Simon) · AI Product & Applied AI</p>
        <h1>I design AI systems that connect model capability, user needs and real organisational workflows.</h1>
        <p class="hero-lede">
          With a background spanning physics, LLM workflows, education research and organisational leadership,
          I work across technical implementation, product judgement and AI adoption.
        </p>
        <div class="button-row">
          <a class="button button-primary" href="#selected-work">View selected work</a>
          <a class="button button-secondary" href={withBase("/resume/")}>View résumé</a>
        </div>
        <div class="hero-links" aria-label="Direct links">
          <a href={site.linkedin} rel="me">LinkedIn</a>
          <span aria-hidden="true">·</span>
          <a href={"mailto:" + site.email}>Email</a>
          <span aria-hidden="true">·</span>
          <a href={withBase("/leadership/")}>Leadership</a>
          <span aria-hidden="true">·</span>
          <a href={withBase("/research/")}>Research</a>
        </div>
      </div>

      <figure class="portrait-frame">
        <picture>
          <source
            type="image/webp"
            srcset={withBase(site.portrait.webpSmall) + " 480w, " + withBase(site.portrait.webp) + " 724w"}
            sizes="(max-width: 760px) calc(100vw - 40px), 38vw"
          />
          <img
            src={withBase(site.portrait.jpeg)}
            srcset={withBase(site.portrait.jpegSmall) + " 480w, " + withBase(site.portrait.jpeg) + " 724w"}
            sizes="(max-width: 760px) calc(100vw - 40px), 38vw"
            width={site.portrait.width}
            height={site.portrait.height}
            alt={site.portrait.alt}
            fetchpriority="high"
            decoding="async"
          />
        </picture>
        <figcaption>
          <span>Physics → Applied AI</span>
          <strong>Education, users and organisational adoption</strong>
        </figcaption>
      </figure>
    </div>

    <div class="shell capability-rail" aria-label="Professional focus">
      <span>Model capability</span>
      <i aria-hidden="true"></i>
      <span>Workflow design</span>
      <i aria-hidden="true"></i>
      <span>Evaluation</span>
      <i aria-hidden="true"></i>
      <span>Trust</span>
      <i aria-hidden="true"></i>
      <span>Adoption</span>
    </div>
  </section>

  <section class="section" id="selected-work">
    <div class="shell">
      <SectionIntro
        eyebrow="Selected work"
        title="Evidence across models, users and organisations."
        description="Three case studies chosen for relevance, not chronology. Each states what is known, what is withheld and what still needs evidence."
        align="split"
      />
      <div class="project-grid">
        {featuredProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
      <p class="section-link"><a class="text-link" href={withBase("/work/")}>View all project context <span aria-hidden="true">→</span></a></p>
    </div>
  </section>

  <section class="section section-ink">
    <div class="shell">
      <SectionIntro
        eyebrow="Capabilities"
        title="One system, four lenses."
        description="The strongest work sits where technical choices, user evidence, product judgement and organisational context meet."
        align="split"
      />
      <div class="capability-grid">
        {
          capabilities.map((capability, index) => (
            <article>
              <span class="capability-number">{String(index + 1).padStart(2, "0")}</span>
              <h3>{capability.group}</h3>
              <ul>
                {capability.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell experience-layout">
      <SectionIntro
        eyebrow="Selected experience"
        title="Technical work informed by real users."
        description="A concise view of the experiences most relevant to applied AI and product adoption."
      />
      <ol class="experience-list">
        {
          selectedExperience.map((item) => (
            <li>
              <time>{item.period}</time>
              <div>
                <p>{item.organisation}</p>
                <h3>{item.role}</h3>
                <span>{item.summary}</span>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section-warm">
    <div class="shell research-preview">
      <SectionIntro
        eyebrow="Research & writing"
        title="Product questions grounded in evidence."
        description="Research is presented with precise status labels and without turning contextual findings into universal claims."
      />
      <div class="research-preview-list">
        {
          researchItems.slice(0, 2).map((item) => (
            <article>
              <div>
                <p class="status-label">{item.status}</p>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
              {"href" in item && item.href && <a class="text-link" href={withBase(item.href)}>Read the case study <span aria-hidden="true">→</span></a>}
            </article>
          ))
        }
      </div>
      <p class="section-link"><a class="text-link" href={withBase("/research/")}>View research record <span aria-hidden="true">→</span></a></p>
    </div>
  </section>

  <section class="section trajectory">
    <div class="shell trajectory-grid">
      <p class="eyebrow">Working thesis</p>
      <div>
        <h2>Useful AI is a product and organisational problem, not only a model problem.</h2>
        <p>
          Physics taught me to model systems. Applied AI taught me to connect components. Education research and
          leadership taught me to ask who must trust the system, how work changes and what evidence counts.
        </p>
      </div>
    </div>
  </section>

  <div class="shell section">
    <ContactPanel />
  </div>
</BaseLayout>
